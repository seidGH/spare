# -------- Stage 1: Build React app --------
--------------------------------------
# 1. Start with a base image
FROM node:18-alpine

 It Switches the "Context"
When Docker sees a second FROM instruction, it effectively starts a brand-new, empty image.

It leaves behind the Node.js runtime, the node_modules folder, and all the "source code" clutter from the previous stage.

This is why your final image size drops from ~1GB (Node) to ~20MB (Nginx Alpine).
# 2. Set the working directory
WORKDIR /app

# 3. Copy ONLY dependency files (Strategic move!)
COPY package.json package-lock.json ./

# 4. Install dependencies (This layer is cached)
RUN npm install

# 5. Copy the rest of the source code
COPY . .

# 6. Build the app
RUN npm run build
#Nginx server 
Nginx is purpose-built to deliver these static files extremely fast with very low memory overhead.
why we chose nginx server over reactserver or vite is its speed and low memory usage to deliver static app folder or webiste to many users at same time
andles thousands of simultaneous users much more efficiently than a development server like Vite or Create React App.
# -------- Stage 2: Serve with Nginx --------
FROM nginx:alpine

# remove default nginx html
RUN rm -rf /usr/share/nginx/html/*

# copy build output
COPY --from=builder /app/build /usr/share/nginx/html

# expose port
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]

